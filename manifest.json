{
  "name": "ESWU",
  "short_name": "ESWU",
  "start_url": "./index.html",
  "display": "minimal-ui",
  "background_color": "#1a365d",
  "theme_color": "#1a365d",
  "icons": [
    { "src": "./icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "./icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text":  "text",
      "url":   "url",
      "files": [
        { "name": "pdf", "accept": ["application/pdf", "image/*"] }
      ]
    }
  }
}
